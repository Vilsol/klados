{
  "schemaVersion": 1,
  "name": "node-annotator",
  "version": "0.1.0",
  "displayName": "Node Annotator",
  "description": "Enriches nodes with taint count and readiness summary. Demonstrates all SDK capabilities.",
  "minHostVersion": "0.1.0",
  "permissions": {
    "resources": [
      {
        "group": "",
        "version": "v1",
        "resource": "nodes",
        "verbs": ["list", "get", "watch"]
      }
    ],
    "storage": true,
    "events": true
  },
  "extensions": {
    "enrichers": {
      "gvrs": ["core.v1.nodes"],
      "wasm": "dist/plugin-tiny.wasm"
    },
    "descriptors": [
      "descriptors/nodes.yaml"
    ],
    "detailTabs": [
      {
        "gvr": "core.v1.nodes",
        "id": "node-annotator-info",
        "label": "Annotations",
        "component": "ui/NodeAnnotation.js"
      }
    ],
    "sidebar": [
      { "category": "Cluster", "label": "Nodes", "gvr": "core.v1.nodes" }
    ],
    "commands": [
      { "id": "node-annotator-taint-report", "label": "Node Annotator: Taint Report" },
      { "id": "node-annotator-cluster-health", "label": "Node Annotator: Cluster Health", "component": "ui/ClusterHealthOverlay.js" }
    ],
    "overviewFields": [
      { "id": "node-taint-overview", "label": "Taints", "gvr": "core.v1.nodes", "component": "ui/NodeTaintBadge.js" }
    ],
    "listColumns": [
      { "id": "node-taint-column", "label": "Taints", "gvr": "core.v1.nodes", "component": "ui/NodeTaintBadge.js" }
    ],
    "contextMenu": [
      { "id": "node-copy-name", "label": "Copy Node Name", "gvr": "core.v1.nodes", "component": "ui/NodeContextItem.js" }
    ],
    "headerWidgets": [
      { "id": "node-annotator-header", "label": "Node Annotator", "component": "ui/NodeHeaderWidget.js" }
    ],
    "statusBar": [
      { "id": "node-annotator-status", "label": "Node Annotator", "component": "ui/NodeStatusWidget.js" }
    ],
    "settings": {
      "schema": {
        "type": "object",
        "properties": {
          "refreshInterval": {
            "type": "integer",
            "title": "Refresh Interval",
            "description": "How often to re-enrich node data (in seconds)",
            "default": 30,
            "minimum": 5,
            "maximum": 300
          },
          "showTaintCount": {
            "type": "boolean",
            "title": "Show Taint Count",
            "description": "Display taint count badge in node list",
            "default": true
          },
          "healthThreshold": {
            "type": "string",
            "title": "Health Threshold",
            "description": "Minimum readiness level to consider a node healthy",
            "enum": ["any", "ready", "ready-no-pressure"],
            "default": "ready"
          },
          "highlightColor": {
            "type": "string",
            "title": "Highlight Color",
            "description": "Accent color for annotated nodes",
            "format": "color",
            "default": "#22c55e"
          }
        }
      }
    },
    "metrics": [
      {
        "gvr": "core.v1.nodes",
        "queries": [
          {
            "name": "Disk Available",
            "query": "node_filesystem_avail_bytes{node=\"{{name}}\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{node=\"{{name}}\", mountpoint=\"/\", fstype!=\"tmpfs\"}",
            "unit": "ratio"
          },
          {
            "name": "Network Receive",
            "query": "sum(rate(node_network_receive_bytes_total{node=\"{{name}}\", device!=\"lo\"}[5m]))",
            "unit": "bytes"
          },
          {
            "name": "Pod Count",
            "query": "kubelet_running_pods{node=\"{{name}}\"}",
            "unit": ""
          }
        ]
      }
    ]
  }
}
