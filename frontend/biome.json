{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": false
  },
  "files": {
    "includes": ["**", "!!dist", "!!bindings"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 140,
    "attributePosition": "auto",
    "bracketSpacing": false,
    "expand": "auto",
    "trailingNewline": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "performance": "error",
      "a11y": "error",
      "suspicious": "error",
      "correctness": "error",
      "style": "error",
      "complexity": "error",
      "security": "error"
    }
  },
  "javascript": {
    "experimentalEmbeddedSnippetsEnabled": true,
    "formatter": {
      "enabled": true,
      "quoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 140,
      "bracketSpacing": false,
      "expand": "auto",
      "operatorLinebreak": "after",
      "trailingNewline": true
    },
    "linter": {
      "enabled": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 140,
      "trailingCommas": "none",
      "bracketSpacing": false,
      "expand": "auto",
      "trailingNewline": true
    },
    "linter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 140,
      "trailingNewline": true
    },
    "linter": {
      "enabled": true
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 140,
      "attributePosition": "auto",
      "whitespaceSensitivity": "css",
      "indentScriptAndStyle": true,
      "selfCloseVoidElements": "never",
      "trailingNewline": true
    },
    "linter": {
      "enabled": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off",
            "noRestrictedGlobals": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off",
            "noUndeclaredVariables": "off"
          },
          "suspicious": {
            "noAssignInExpressions": "off",
            "noGlobalAssign": "off",
            "noUnassignedVariables": "off"
          },
          "complexity": {
            "noVoid": "off"
          }
        }
      }
    },
    {
      "includes": ["**"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off",
            "useQwikValidLexicalScope": "off"
          },
          "style": {
            "noDefaultExport": "off",
            "useNamingConvention": "off",
            "useFilenamingConvention": "off",
            "useExportsLast": "off",
            "useDefaultSwitchClause": "off",
            "noMagicNumbers": "off"
          },
          "suspicious": {
            "noBitwiseOperators": "off"
          },
          "complexity": {
            "noExcessiveLinesPerFunction": "off",
            "useMaxParams": "off",
            "noExcessiveCognitiveComplexity": "off"
          },
          "security": {
            "noSecrets": {
              "level": "error",
              "options": {
                "entropyThreshold": 50
              }
            }
          }
        }
      }
    }
  ]
}
